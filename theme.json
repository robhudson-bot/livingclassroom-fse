{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"customDuotone": false,
			"palette": [
				{ "slug": "primary",      "color": "#007ea6", "name": "Brand Teal" },
				{ "slug": "primary-10",   "color": "#e5f2f6", "name": "Brand Teal 10%" },
				{ "slug": "primary-20",   "color": "#cce5ed", "name": "Brand Teal 20%" },
				{ "slug": "primary-40",   "color": "#99cbda", "name": "Brand Teal 40%" },
				{ "slug": "primary-60",   "color": "#66b2c8", "name": "Brand Teal 60%" },
				{ "slug": "primary-80",   "color": "#3398b5", "name": "Brand Teal 80%" },

				{ "slug": "secondary",    "color": "#bc945b", "name": "Brand Gold" },
				{ "slug": "secondary-10", "color": "#f8f4ef", "name": "Brand Gold 10%" },
				{ "slug": "secondary-20", "color": "#f1e9de", "name": "Brand Gold 20%" },
				{ "slug": "secondary-40", "color": "#e4d4bd", "name": "Brand Gold 40%" },
				{ "slug": "secondary-60", "color": "#d7bf9d", "name": "Brand Gold 60%" },
				{ "slug": "secondary-80", "color": "#caa97c", "name": "Brand Gold 80%" },

				{ "slug": "anchor",       "color": "#003e51", "name": "RIA Dark Teal" },
				{ "slug": "surface",      "color": "#ffffff", "name": "Surface White" },
				{ "slug": "ink",          "color": "#003e51", "name": "Body Ink" },
				{ "slug": "muted",        "color": "#686868", "name": "Muted / Meta" },
				{ "slug": "panel",        "color": "#edf1f7", "name": "Blockquote Panel" },
				{ "slug": "error",        "color": "#c02b0a", "name": "Error Red" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": true,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "source-sans",
					"name": "Source Sans Pro",
					"fontFamily": "'Source Sans Pro', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"fontFace": [
						{ "fontFamily": "Source Sans Pro", "fontWeight": "300", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/source-sans-pro-300.woff2" ] },
						{ "fontFamily": "Source Sans Pro", "fontWeight": "400", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/source-sans-pro-400.woff2" ] },
						{ "fontFamily": "Source Sans Pro", "fontWeight": "400", "fontStyle": "italic", "fontDisplay": "swap", "src": [ "file:./assets/fonts/source-sans-pro-400-italic.woff2" ] },
						{ "fontFamily": "Source Sans Pro", "fontWeight": "500", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/source-sans-pro-500.woff2" ] },
						{ "fontFamily": "Source Sans Pro", "fontWeight": "700", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/source-sans-pro-700.woff2" ] },
						{ "fontFamily": "Source Sans Pro", "fontWeight": "900", "fontStyle": "normal", "fontDisplay": "swap", "src": [ "file:./assets/fonts/source-sans-pro-900.woff2" ] }
					]
				}
			],
			"fontSizes": [
				{ "slug": "eyebrow", "size": "0.6875rem", "name": "Eyebrow (11px)" },
				{ "slug": "xs",    "size": "0.875rem", "name": "Meta (14px)" },
				{ "slug": "sm",    "size": "1rem",     "name": "Body Small (16px)" },
				{ "slug": "base",  "size": "1.125rem", "name": "Body (18px)" },
				{ "slug": "lg",    "size": "1.375rem", "name": "Button / Footer Link (22px)" },
				{ "slug": "xl",    "size": "clamp(1.25rem, 2vw + 0.5rem, 1.8rem)",  "name": "H3 (20-28.8px fluid)", "fluid": false },
				{ "slug": "xxl",   "size": "clamp(1.5rem, 3.5vw + 0.5rem, 2.25rem)", "name": "H2 (24-36px fluid)",   "fluid": false },
				{ "slug": "xxxl",  "size": "clamp(1.75rem, 4.5vw + 0.5rem, 2.625rem)", "name": "H1 / Hero (28-42px fluid)", "fluid": false }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vw" ],
			"padding": true,
			"margin": true,
			"blockGap": true,
			"spacingSizes": [
				{ "slug": "10", "size": "0.25rem", "name": "2XS" },
				{ "slug": "20", "size": "0.5rem",  "name": "XS" },
				{ "slug": "30", "size": "0.75rem", "name": "Small" },
				{ "slug": "40", "size": "1rem",    "name": "Medium" },
				{ "slug": "50", "size": "1.5rem",  "name": "Large" },
				{ "slug": "60", "size": "2.25rem", "name": "XL" },
				{ "slug": "70", "size": "3.375rem","name": "2XL" },
				{ "slug": "80", "size": "5.0625rem","name": "3XL" }
			]
		},
		"layout": {
			"contentSize": "960px",
			"wideSize": "1200px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|source-sans",
			"fontSize": "var:preset|font-size|base",
			"fontWeight": "400",
			"lineHeight": "1.55"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--40)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--40)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40)"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xxxl",
					"fontWeight": "300",
					"lineHeight": "1.2"
				},
				"color": { "text": "var(--wp--preset--color--ink)" },
				"spacing": { "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--40)" } }
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|xxl",
					"fontWeight": "300",
					"lineHeight": "1.25"
				},
				"color": { "text": "var(--wp--preset--color--ink)" },
				"spacing": { "margin": { "top": "var(--wp--preset--spacing--50)", "bottom": "var(--wp--preset--spacing--30)" } }
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"fontWeight": "900",
					"lineHeight": "1.2"
				},
				"color": { "text": "var(--wp--preset--color--ink)" },
				"spacing": { "margin": { "top": "var(--wp--preset--spacing--50)", "bottom": "var(--wp--preset--spacing--30)" } }
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"fontWeight": "700",
					"lineHeight": "1.3"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontWeight": "700",
					"lineHeight": "1.4"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|sm",
					"fontWeight": "700",
					"lineHeight": "1.4",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				},
				"color": { "text": "var(--wp--preset--color--muted)" }
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" },
				"typography": { "textDecoration": "underline" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--primary-80)" }
				},
				":focus": {
					"color": { "text": "var(--wp--preset--color--primary-80)" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--surface)"
				},
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "1px",
					"lineHeight": "1"
				},
				"border": { "radius": "6px", "width": "0" },
				"spacing": {
					"padding": { "top": "18px", "right": "24px", "bottom": "18px", "left": "24px" }
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--secondary)",
						"text": "var(--wp--preset--color--anchor)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--primary-80)",
						"text": "var(--wp--preset--color--surface)"
					}
				}
			},
			"caption": {
				"typography": { "fontSize": "var:preset|font-size|xs", "fontStyle": "italic" },
				"color": { "text": "var(--wp--preset--color--muted)" }
			}
		},
		"blocks": {
			"core/quote": {
				"color": {
					"background": "var(--wp--preset--color--panel)",
					"text": "var(--wp--preset--color--muted)"
				},
				"border": {
					"left": { "color": "var(--wp--preset--color--secondary)", "width": "6px", "style": "solid" }
				},
				"spacing": {
					"padding": { "top": "1.25rem", "right": "1.5rem", "bottom": "1.25rem", "left": "1.5rem" }
				},
				"typography": { "fontStyle": "italic" }
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontWeight": "400",
					"textTransform": "uppercase",
					"letterSpacing": "0.02em"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"core/site-title": {
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"fontWeight": "700"
				},
				"color": { "text": "var(--wp--preset--color--anchor)" }
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|xxxl",
					"fontWeight": "300",
					"lineHeight": "1.2"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"core/separator": {
				"color": { "background": "var(--wp--preset--color--secondary)" },
				"border": { "color": "var(--wp--preset--color--secondary)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header",     "title": "Header",       "area": "header" },
		{ "name": "footer",     "title": "Footer",       "area": "footer" },
		{ "name": "page-hero",  "title": "Page Hero",    "area": "uncategorized" }
	],
	"customTemplates": [
		{ "name": "page-subpage",         "title": "Subpage",         "postTypes": [ "page" ] },
		{ "name": "page-building-blocks", "title": "Building Blocks", "postTypes": [ "page" ] },
		{ "name": "page-news-events",     "title": "News & Events",   "postTypes": [ "page" ] }
	]
}
