{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "deep-teal", "color": "#003E51", "name": "Deep Teal" },
				{ "slug": "medium-teal", "color": "#29637F", "name": "Medium Teal" },
				{ "slug": "bright-teal", "color": "#007EA6", "name": "Bright Teal" },
				{ "slug": "link-blue", "color": "#007ACC", "name": "Link Blue" },
				{ "slug": "gold", "color": "#CFA76C", "name": "Gold" },
				{ "slug": "orange", "color": "#F8991D", "name": "Orange" },
				{ "slug": "cream", "color": "#FFF2E2", "name": "Cream" },
				{ "slug": "off-white", "color": "#F5F5F5", "name": "Off White" },
				{ "slug": "white", "color": "#FFFFFF", "name": "White" },
				{ "slug": "dark-charcoal", "color": "#32373C", "name": "Dark Charcoal" },
				{ "slug": "mid-gray", "color": "#808080", "name": "Mid Gray" },
				{ "slug": "text-gray", "color": "#686868", "name": "Text Gray" },
				{ "slug": "error-red", "color": "#C02B0A", "name": "Error Red" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": true,
			"fontFamilies": [
				{
					"slug": "source-sans-pro",
					"name": "Source Sans Pro",
					"fontFamily": "'Source Sans Pro', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Source Sans Pro",
							"fontWeight": "300",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/source-sans-pro-300.woff2" ]
						},
						{
							"fontFamily": "Source Sans Pro",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/source-sans-pro-400.woff2" ]
						},
						{
							"fontFamily": "Source Sans Pro",
							"fontWeight": "400",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/source-sans-pro-400-italic.woff2" ]
						},
						{
							"fontFamily": "Source Sans Pro",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/source-sans-pro-500.woff2" ]
						},
						{
							"fontFamily": "Source Sans Pro",
							"fontWeight": "700",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/source-sans-pro-700.woff2" ]
						},
						{
							"fontFamily": "Source Sans Pro",
							"fontWeight": "900",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/source-sans-pro-900.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "13px", "name": "Small" },
				{ "slug": "medium", "size": "16px", "name": "Medium" },
				{ "slug": "regular", "size": "18px", "name": "Regular" },
				{ "slug": "large", "size": "22px", "name": "Large" },
				{ "slug": "x-large", "size": "28.8px", "name": "Extra Large" },
				{ "slug": "xx-large", "size": "42px", "name": "2X Large" }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vw" ],
			"spacingSizes": [
				{ "slug": "10", "size": "8px", "name": "XS" },
				{ "slug": "20", "size": "16px", "name": "Small" },
				{ "slug": "30", "size": "20px", "name": "Medium" },
				{ "slug": "40", "size": "28px", "name": "Large" },
				{ "slug": "50", "size": "40px", "name": "XL" },
				{ "slug": "60", "size": "80px", "name": "2XL" },
				{ "slug": "70", "size": "95px", "name": "3XL" }
			]
		},
		"layout": {
			"contentSize": "885px",
			"wideSize": "1000px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--deep-teal)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--source-sans-pro)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"lineHeight": "1.75"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" },
				"spacing": { "margin": { "bottom": "var(--wp--preset--spacing--30)" } }
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "300",
					"lineHeight": "1.33"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" },
				"spacing": { "margin": { "bottom": "var(--wp--preset--spacing--30)" } }
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "900",
					"lineHeight": "1.3"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" },
				"spacing": { "margin": { "bottom": "var(--wp--preset--spacing--30)" } }
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700",
					"lineHeight": "1.4"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" },
				"spacing": { "margin": { "bottom": "var(--wp--preset--spacing--20)" } }
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--regular)",
					"fontWeight": "700",
					"lineHeight": "1.4"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" },
				"spacing": { "margin": { "bottom": "var(--wp--preset--spacing--20)" } }
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "700",
					"lineHeight": "1.4"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" },
				"spacing": { "margin": { "bottom": "var(--wp--preset--spacing--20)" } }
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--link-blue)" },
				"typography": { "textDecoration": "none" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--medium-teal)" },
					"typography": { "textDecoration": "underline" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--medium-teal)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700",
					"textTransform": "uppercase"
				},
				"border": { "radius": "4px" },
				"spacing": {
					"padding": {
						"top": "18px",
						"right": "24px",
						"bottom": "18px",
						"left": "24px"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--orange)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "italic"
				},
				"color": { "text": "var(--wp--preset--color--text-gray)" }
			}
		},
		"blocks": {
			"core/quote": {
				"color": {
					"background": "var(--wp--preset--color--cream)",
					"text": "var(--wp--preset--color--text-gray)"
				},
				"border": {
					"left": {
						"color": "var(--wp--preset--color--deep-teal)",
						"width": "12px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"top": "21px",
						"right": "20px",
						"bottom": "21px",
						"left": "20px"
					}
				},
				"typography": { "fontStyle": "italic" }
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--regular)",
					"fontWeight": "400",
					"textTransform": "uppercase"
				},
				"color": { "text": "var(--wp--preset--color--medium-teal)" }
			},
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700"
				},
				"color": { "text": "var(--wp--preset--color--deep-teal)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-subpage", "title": "Subpage", "postTypes": [ "page" ] },
		{ "name": "page-building-blocks", "title": "Building Blocks", "postTypes": [ "page" ] },
		{ "name": "page-news-events", "title": "News & Events", "postTypes": [ "page" ] }
	]
}
